# Frontend Environment Configuration

# API Base URL - Update based on your deployment environment
# Local development: http://localhost:5000
# LAN access: http://192.168.x.x:5000 (adjust IP to your server)
# Production: https://your-domain.com
VITE_API_BASE_URL=http://localhost:5000/api

# Can also reference the backend directly by hostname
# VITE_API_BASE_URL=http://backend:5000/api
